{
  "webservice" : "/restcountries/country",
  "errorType": "jsonWithStatus",
  "type": "precise",
  "inputs" : [ "q" ],
  "latency": "1000",
  "maxRequestsPerMinute": "60",
  "maxRequests": "2000",
  "where" : [
    ["?subject", "hasCca3", "$q"]
  ],
  "inputMode": "upperCase",
  "returnTemplate": "restcountries/restcountries.json.ftl",
  "db": "restcountries-api"
}