{
  "webservice" : "/arxiv/work",
  "errorType": "jsonWithStatus",
  "type": "precise",
  "latency": "1000",
  "maxRequestsPerMinute": "60",
  "maxRequests": "2000",
  "inputs" : [ "arxivId" ],
  "where" : [
    ["?subject", "key", "$arxivId"]
  ],
  "returnTemplate": "arxiv/arxiv.json.ftl",
  "db": "arxiv"
}