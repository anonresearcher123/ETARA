{
  "webservice" : "/geodb/country",
  "errorType": "jsonWithStatus",
  "type": "precise",
  "inputs" : [ "q" ],
  "latency": "1000",
  "maxRequestsPerMinute": "60",
  "maxRequests": "2000",
  "where" : [
    ["?subject", "hasAlphaNumeric", "$q"]
  ],
  "inputMode": "lowerCase",
  "returnTemplate": "geodb/geodb.json.ftl",
  "db": "geodb"
}